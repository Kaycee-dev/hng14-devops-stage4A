#!/usr/bin/env bash
# swiftdeploy - manifest-driven CLI for SwiftDeploy Stage 4B.

set -euo pipefail

PY=""
for cand in python3 python; do
    cand_path="$(command -v "$cand" 2>/dev/null || true)"
    if [[ -n "${cand_path}" ]] && "${cand_path}" --version >/dev/null 2>&1; then
        PY="${cand_path}"
        break
    fi
done

if [[ -z "${PY}" ]]; then
    echo "swiftdeploy: no working python interpreter found (need python3 or python)" >&2
    exit 127
fi

ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
export SWIFTDEPLOY_ROOT="${ROOT}"

exec "${PY}" -m swiftdeploy_lib.cli "$@"
