#!/usr/bin/env bash
# swiftdeploy - manifest-driven CLI for the Stage 4A stack.
#
# Subcommands implemented in this packet (SD4-CLI-001):
#   init       Render nginx.conf and docker-compose.yml from manifest.yaml.
#   validate   Run the 5 brief-mandated pre-flight checks.
#
# Subsequent packets add: deploy, promote, teardown.

set -euo pipefail

# -----------------------------------------------------------------------------
# Resolve the Python interpreter (D-006).
# A path returned by `command -v` is not enough; on Windows the WindowsApps
# `python3` is a Store-stub that exits non-zero. Probe each candidate with
# `--version` so we catch broken shims.
# -----------------------------------------------------------------------------
PY=""
for cand in python3 python; do
    cand_path="$(command -v "$cand" 2>/dev/null || true)"
    if [[ -n "${cand_path}" ]] && "${cand_path}" --version >/dev/null 2>&1; then
        PY="${cand_path}"
        break
    fi
done
if [[ -z "${PY}" ]]; then
    echo "swiftdeploy: no working python interpreter found (need python3 or python)" >&2
    exit 127
fi

# -----------------------------------------------------------------------------
# Repo-relative paths.
# -----------------------------------------------------------------------------
ROOT="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
MANIFEST="${ROOT}/manifest.yaml"
TEMPLATE_DIR="${ROOT}/templates"
NGINX_TMPL="${TEMPLATE_DIR}/nginx.conf.tmpl"
COMPOSE_TMPL="${TEMPLATE_DIR}/docker-compose.tmpl"
NGINX_OUT="${ROOT}/nginx.conf"
COMPOSE_OUT="${ROOT}/docker-compose.yml"

# -----------------------------------------------------------------------------
# Output helpers. Plain text so screenshots are unambiguous.
# -----------------------------------------------------------------------------
log()   { printf '%s\n' "$*"; }
pass()  { printf '[PASS] %s\n' "$*"; }
fail()  { printf '[FAIL] %s\n' "$*" >&2; }
die()   { printf 'swiftdeploy: %s\n' "$*" >&2; exit 1; }

# -----------------------------------------------------------------------------
# render_templates: parse manifest -> render templates -> atomic write.
# Atomic write = temp file in same dir, then mv. Guarantees no partial output
# survives a crash mid-render.
# -----------------------------------------------------------------------------
render_templates() {
    [[ -f "${MANIFEST}" ]]      || die "manifest.yaml not found at ${MANIFEST}"
    [[ -f "${NGINX_TMPL}" ]]    || die "templates/nginx.conf.tmpl missing"
    [[ -f "${COMPOSE_TMPL}" ]]  || die "templates/docker-compose.tmpl missing"

    "${PY}" - "${MANIFEST}" "${NGINX_TMPL}" "${COMPOSE_TMPL}" "${NGINX_OUT}" "${COMPOSE_OUT}" <<'PYEOF'
import os, sys, tempfile
from pathlib import Path
from string import Template
try:
    import yaml
except ImportError:
    sys.stderr.write("swiftdeploy: PyYAML is required (pip install pyyaml)\n")
    sys.exit(127)

manifest_path, nginx_tmpl, compose_tmpl, nginx_out, compose_out = sys.argv[1:6]

with open(manifest_path, "r", encoding="utf-8") as fh:
    m = yaml.safe_load(fh) or {}

def need(d, key, where):
    v = d.get(key)
    if v in (None, ""):
        sys.stderr.write(f"swiftdeploy: manifest.{where}.{key} is missing or empty\n")
        sys.exit(2)
    return v

services = m.get("services") or {}
nginx    = m.get("nginx") or {}
network  = m.get("network") or {}

ctx = {
    # Required base fields (brief mandate, no defaults).
    "SERVICE_IMAGE":  str(need(services, "image",        "services")),
    "SERVICE_PORT":   str(need(services, "port",         "services")),
    "NGINX_IMAGE":    str(need(nginx,    "image",        "nginx")),
    "NGINX_PORT":     str(need(nginx,    "port",         "nginx")),
    "NETWORK_NAME":   str(need(network,  "name",         "network")),
    "NETWORK_DRIVER": str(need(network,  "driver_type",  "network")),
    # Optional extensions with defaults (D-009).
    "MODE":            str(services.get("mode",           "stable")),
    "APP_VERSION":     str(services.get("version",        "1.0.0")),
    "RESTART_POLICY":  str(services.get("restart_policy", "unless-stopped")),
    "LOG_VOLUME":      str(services.get("log_volume",     "swiftdeploy-logs")),
    "PROXY_TIMEOUT":   str(nginx.get("proxy_timeout",     "30")),
    "ERROR_CONTACT":   str(nginx.get("error_contact",     "ops@swiftdeploy.local")),
}

if str(ctx["MODE"]) not in ("stable", "canary"):
    sys.stderr.write(f"swiftdeploy: services.mode must be 'stable' or 'canary' (got {ctx['MODE']!r})\n")
    sys.exit(2)

def atomic_write(target, text):
    target_path = Path(target)
    target_path.parent.mkdir(parents=True, exist_ok=True)
    fd, tmp = tempfile.mkstemp(prefix=".swiftdeploy.", dir=str(target_path.parent))
    try:
        with os.fdopen(fd, "w", encoding="utf-8", newline="\n") as out:
            out.write(text)
        os.replace(tmp, target_path)
    except Exception:
        try: os.unlink(tmp)
        except FileNotFoundError: pass
        raise

for tmpl_path, out_path in ((nginx_tmpl, nginx_out), (compose_tmpl, compose_out)):
    raw = Path(tmpl_path).read_text(encoding="utf-8")
    rendered = Template(raw).safe_substitute(ctx)
    atomic_write(out_path, rendered)

print(f"rendered nginx.conf       <- {nginx_tmpl}")
print(f"rendered docker-compose.yml <- {compose_tmpl}")
PYEOF
}

# -----------------------------------------------------------------------------
# cmd_init: brief-mandated `init` subcommand.
# -----------------------------------------------------------------------------
cmd_init() {
    log "swiftdeploy init: rendering generated files from ${MANIFEST}"
    render_templates
    log "OK: nginx.conf and docker-compose.yml regenerated."
}

# -----------------------------------------------------------------------------
# cmd_validate: 5 brief-mandated pre-flight checks. Exit non-zero on any fail.
# -----------------------------------------------------------------------------
cmd_validate() {
    local fail_count=0

    # Check 1: manifest.yaml exists and is valid YAML. The path is passed as
    # argv (not embedded in the heredoc) so MSYS path translation works on
    # Windows shells. Heredoc delimiter is quoted to prevent shell expansion
    # inside the Python body.
    if [[ ! -f "${MANIFEST}" ]]; then
        fail "manifest.yaml does not exist at ${MANIFEST}"
        fail_count=$((fail_count + 1))
    elif ! "${PY}" - "${MANIFEST}" <<'PYEOF' >/dev/null 2>&1
import sys, yaml
yaml.safe_load(open(sys.argv[1], "r", encoding="utf-8"))
PYEOF
    then
        fail "manifest.yaml exists but is not valid YAML"
        fail_count=$((fail_count + 1))
    else
        pass "manifest.yaml exists and is valid YAML"
    fi

    # Check 2: required fields are present and non-empty.
    if [[ -f "${MANIFEST}" ]]; then
        local missing
        missing="$(
            "${PY}" - "${MANIFEST}" <<'PYEOF'
import sys, yaml
m = yaml.safe_load(open(sys.argv[1], "r", encoding="utf-8")) or {}
required = [
    ("services","image"), ("services","port"),
    ("nginx","image"),    ("nginx","port"),
    ("network","name"),   ("network","driver_type"),
]
missing = []
for parent, key in required:
    section = (m.get(parent) or {})
    val = section.get(key)
    if val in (None, ""):
        missing.append(f"{parent}.{key}")
print(",".join(missing))
PYEOF
        )" || missing="parser_error"
        if [[ -z "${missing}" ]]; then
            pass "all required manifest fields are present and non-empty"
        else
            fail "required manifest fields missing or empty: ${missing}"
            fail_count=$((fail_count + 1))
        fi
    fi

    # Check 3: the docker image referenced in the manifest exists locally.
    local image=""
    if [[ -f "${MANIFEST}" ]]; then
        image="$("${PY}" - "${MANIFEST}" <<'PYEOF' 2>/dev/null || true
import sys, yaml
m = yaml.safe_load(open(sys.argv[1], "r", encoding="utf-8")) or {}
print((m.get("services") or {}).get("image") or "")
PYEOF
        )"
    fi
    if [[ -z "${image}" ]]; then
        fail "cannot determine services.image from manifest"
        fail_count=$((fail_count + 1))
    elif docker image inspect "${image}" >/dev/null 2>&1; then
        pass "docker image '${image}' is present locally"
    else
        fail "docker image '${image}' is not present locally (run docker build)"
        fail_count=$((fail_count + 1))
    fi

    # Check 4: the nginx port is not already bound on the host. socket.bind()
    # is the same kernel call nginx will use, so a successful bind here means
    # nginx will succeed too.
    local nginx_port=""
    if [[ -f "${MANIFEST}" ]]; then
        nginx_port="$("${PY}" - "${MANIFEST}" <<'PYEOF' 2>/dev/null || true
import sys, yaml
m = yaml.safe_load(open(sys.argv[1], "r", encoding="utf-8")) or {}
print((m.get("nginx") or {}).get("port") or "")
PYEOF
        )"
    fi
    if [[ -z "${nginx_port}" ]]; then
        fail "cannot determine nginx.port from manifest"
        fail_count=$((fail_count + 1))
    else
        local probe_rc
        "${PY}" - "${nginx_port}" <<'PYEOF' && probe_rc=0 || probe_rc=$?
import socket, sys
port = int(sys.argv[1])
sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 0)
try:
    sock.bind(("0.0.0.0", port))
except OSError:
    sys.exit(1)
finally:
    sock.close()
sys.exit(0)
PYEOF
        if [[ "${probe_rc}" -eq 0 ]]; then
            pass "nginx port ${nginx_port} is free on the host"
        else
            fail "nginx port ${nginx_port} is already in use on the host"
            fail_count=$((fail_count + 1))
        fi
    fi

    # Check 5: the generated nginx.conf is syntactically valid (D-013).
    if [[ ! -f "${NGINX_OUT}" ]]; then
        fail "nginx.conf has not been rendered yet (run: swiftdeploy init)"
        fail_count=$((fail_count + 1))
    else
        # --entrypoint nginx bypasses the upstream image's docker-entrypoint.sh,
        # so the output is just nginx -t's own lines (D-013).
        if docker run --rm \
            --entrypoint nginx \
            -v "${NGINX_OUT}:/etc/nginx/conf.d/default.conf:ro" \
            nginx:latest -t -q >/dev/null 2>&1
        then
            pass "rendered nginx.conf passes 'nginx -t' inside nginx:latest"
        else
            # Re-run noisily to surface the actual error in the screenshot.
            docker run --rm \
                --entrypoint nginx \
                -v "${NGINX_OUT}:/etc/nginx/conf.d/default.conf:ro" \
                nginx:latest -t 2>&1 || true
            fail "nginx -t rejected the rendered nginx.conf (see above)"
            fail_count=$((fail_count + 1))
        fi
    fi

    log
    if [[ "${fail_count}" -eq 0 ]]; then
        log "validate: all 5 checks passed"
        exit 0
    else
        log "validate: ${fail_count} check(s) failed"
        exit 1
    fi
}

# -----------------------------------------------------------------------------
# Helpers used by deploy/promote.
# -----------------------------------------------------------------------------
manifest_get() {
    # Read a dotted manifest path (e.g., services.image) from manifest.yaml.
    # Returns the value on stdout, or empty if missing.
    local path="$1"
    "${PY}" - "${MANIFEST}" "${path}" <<'PYEOF' 2>/dev/null
import sys, yaml
m = yaml.safe_load(open(sys.argv[1], "r", encoding="utf-8")) or {}
cur = m
for part in sys.argv[2].split("."):
    if not isinstance(cur, dict):
        sys.exit(0)
    cur = cur.get(part)
    if cur is None:
        sys.exit(0)
print(cur)
PYEOF
}

manifest_set_mode() {
    # In-place rewrite of services.mode. Uses a targeted regex substitution
    # rather than a yaml.safe_dump round-trip so comments, formatting, and
    # quoting in manifest.yaml survive. The brief says promote "updates the
    # mode field in manifest.yaml in-place"; we change exactly that field.
    local target="$1"
    "${PY}" - "${MANIFEST}" "${target}" <<'PYEOF'
import re, sys, yaml
path, target = sys.argv[1], sys.argv[2]
with open(path, "r", encoding="utf-8") as fh:
    text = fh.read()
new_text, n = re.subn(
    r"(?m)^(\s*mode:[ \t]+)\S+",
    lambda m: m.group(1) + target,
    text,
    count=1,
)
if n == 0:
    sys.stderr.write("swiftdeploy: services.mode line not found in manifest.yaml\n")
    sys.exit(2)
with open(path, "w", encoding="utf-8", newline="\n") as fh:
    fh.write(new_text)
# Sanity check: re-parse and confirm services.mode is correct.
with open(path, "r", encoding="utf-8") as fh:
    m = yaml.safe_load(fh) or {}
if (m.get("services") or {}).get("mode") != target:
    sys.stderr.write(f"swiftdeploy: post-edit verification failed; mode is {m.get('services',{}).get('mode')!r}\n")
    sys.exit(2)
PYEOF
}

poll_health_via_nginx() {
    # Block until http://127.0.0.1:NGINX_PORT/healthz returns JSON status=ok,
    # or fail after $1 seconds. Used by deploy and promote.
    local timeout="$1"
    local nginx_port; nginx_port="$(manifest_get nginx.port)"
    [[ -n "${nginx_port}" ]] || die "cannot read nginx.port from manifest"

    local i status_text
    for i in $(seq 1 "${timeout}"); do
        if status_text="$(curl --max-time 2 -fs "http://127.0.0.1:${nginx_port}/healthz" 2>/dev/null)"; then
            local status; status="$(printf '%s' "${status_text}" | "${PY}" -c '
import json, sys
try:
    d = json.loads(sys.stdin.read())
    print(d.get("status", ""))
except Exception:
    pass
' 2>/dev/null || true)"
            if [[ "${status}" == "ok" ]]; then
                printf '  health ok at t=%ds\n' "$i"
                return 0
            fi
        fi
        sleep 1
    done
    return 1
}

confirm_mode_via_nginx() {
    # Hit / through nginx; assert the body.mode matches the expected mode and
    # the X-Mode header is present (canary) or absent (stable).
    local expected="$1"
    local nginx_port; nginx_port="$(manifest_get nginx.port)"
    [[ -n "${nginx_port}" ]] || die "cannot read nginx.port from manifest"

    local headers body
    headers="$(curl --max-time 5 -fsi "http://127.0.0.1:${nginx_port}/" 2>/dev/null)" || return 1
    # Split headers and body for the JSON parse
    body="$(printf '%s' "${headers}" | "${PY}" -c '
import sys
raw = sys.stdin.read().replace("\r\n", "\n")
parts = raw.split("\n\n", 1)
print(parts[1] if len(parts) == 2 else "")
')"
    local body_mode; body_mode="$(printf '%s' "${body}" | "${PY}" -c '
import json, sys
try: print(json.loads(sys.stdin.read()).get("mode",""))
except Exception: pass
')"

    local has_xmode=0
    if printf '%s' "${headers}" | tr -d '\r' | grep -qiE '^x-mode:[[:space:]]*canary$'; then
        has_xmode=1
    fi

    if [[ "${expected}" == "canary" ]]; then
        if [[ "${body_mode}" == "canary" && "${has_xmode}" -eq 1 ]]; then
            pass "canary confirmed: body.mode=canary AND X-Mode: canary header present"
            return 0
        fi
        fail "canary not confirmed (body.mode='${body_mode}', X-Mode header present=${has_xmode})"
        return 1
    else
        if [[ "${body_mode}" == "stable" && "${has_xmode}" -eq 0 ]]; then
            pass "stable confirmed: body.mode=stable AND no X-Mode header"
            return 0
        fi
        fail "stable not confirmed (body.mode='${body_mode}', X-Mode header present=${has_xmode})"
        return 1
    fi
}

# -----------------------------------------------------------------------------
# cmd_deploy: brief mandate is "init -> bring up stack -> block until health
# checks pass or 60s timeout".
# -----------------------------------------------------------------------------
cmd_deploy() {
    log "swiftdeploy deploy: rendering, starting, and waiting for health"
    cmd_init
    log "swiftdeploy deploy: docker compose up -d"
    docker compose -f "${COMPOSE_OUT}" up -d
    log "swiftdeploy deploy: waiting up to 60s for /healthz via nginx..."
    if poll_health_via_nginx 60; then
        log "deploy: stack healthy"
        exit 0
    else
        fail "deploy: /healthz did not return status=ok within 60s"
        log "--- diagnostic: docker compose ps ---"
        docker compose -f "${COMPOSE_OUT}" ps || true
        log "--- diagnostic: app logs (tail 30) ---"
        docker compose -f "${COMPOSE_OUT}" logs --tail=30 app || true
        exit 1
    fi
}

# -----------------------------------------------------------------------------
# cmd_promote: brief mandate is "switch deployment mode with a rolling service
# restart, update mode in manifest.yaml in-place, regenerate compose with the
# new MODE env, restart only the service container, and confirm via /healthz".
# -----------------------------------------------------------------------------
cmd_promote() {
    local target="${1:-}"
    case "${target}" in
        canary|stable) ;;
        *) die "promote requires 'canary' or 'stable' (got '${target:-<empty>}')" ;;
    esac

    log "swiftdeploy promote: target mode=${target}"
    log "  step 1/4: mutating services.mode in manifest.yaml in-place"
    manifest_set_mode "${target}"
    log "  step 2/4: regenerating docker-compose.yml with the new MODE env"
    cmd_init
    log "  step 3/4: recreating the app service only (--no-deps preserves nginx)"
    # `up -d --no-deps --force-recreate app`:
    # - up -d reads the regenerated compose and brings any changed services back up
    # - --no-deps prevents nginx from being recreated alongside (gateway stays up)
    # - --force-recreate guarantees the container is recreated even if Compose
    #   thinks the config is unchanged (e.g., promote canary->canary)
    docker compose -f "${COMPOSE_OUT}" up -d --no-deps --force-recreate app
    log "  step 4/4: waiting for /healthz and confirming mode"
    if ! poll_health_via_nginx 60; then
        fail "promote: /healthz did not return status=ok within 60s after recreate"
        exit 1
    fi
    confirm_mode_via_nginx "${target}" || exit 1
    log "promote: completed; manifest.yaml now records mode=${target}"
}

# -----------------------------------------------------------------------------
# cmd_teardown: brief mandate is "remove all containers, networks, and volumes;
# --clean deletes generated configs".
# -----------------------------------------------------------------------------
cmd_teardown() {
    local clean=0
    for arg in "$@"; do
        case "${arg}" in
            --clean) clean=1 ;;
            *) die "unknown teardown option: ${arg}" ;;
        esac
    done

    if [[ -f "${COMPOSE_OUT}" ]]; then
        log "swiftdeploy teardown: docker compose down -v --remove-orphans"
        # -v removes named volumes (logs); --remove-orphans cleans up containers
        # left behind from prior renames or a previous mode.
        docker compose -f "${COMPOSE_OUT}" down -v --remove-orphans || true
    else
        log "swiftdeploy teardown: no docker-compose.yml found; skipping compose down"
    fi

    if [[ "${clean}" -eq 1 ]]; then
        log "swiftdeploy teardown --clean: removing generated configs"
        rm -f "${NGINX_OUT}" "${COMPOSE_OUT}"
        log "  removed: nginx.conf, docker-compose.yml"
    fi
    log "teardown: complete"
}

# -----------------------------------------------------------------------------
# Dispatcher.
# -----------------------------------------------------------------------------
usage() {
    cat <<USAGE
Usage: swiftdeploy <command> [args]

Commands:
  init                    Render nginx.conf and docker-compose.yml from manifest.yaml.
  validate                Run 5 pre-flight checks; exits non-zero on any failure.
  deploy                  Run init, start the stack, block until /healthz is OK or 60s.
  promote {canary|stable} Switch MODE in-place; restart only the app; confirm via /healthz.
  teardown [--clean]      Remove containers, networks, and volumes; --clean also deletes generated configs.
USAGE
}

main() {
    local cmd="${1:-}"
    case "${cmd}" in
        init)        shift; cmd_init "$@" ;;
        validate)    shift; cmd_validate "$@" ;;
        deploy)      shift; cmd_deploy "$@" ;;
        promote)     shift; cmd_promote "$@" ;;
        teardown)    shift; cmd_teardown "$@" ;;
        ""|-h|--help|help) usage ;;
        *)           usage; exit 64 ;;
    esac
}

main "$@"
